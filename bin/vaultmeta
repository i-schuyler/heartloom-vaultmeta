#!/usr/bin/env bash
# vaultmeta
set -euo pipefail

SCRIPT_NAME="vaultmeta"
VERSION="0.1.0-dev"

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
USER_CONFIG_DIR="${XDG_CONFIG_HOME}/vaultmeta"
USER_CONFIG_FILE="${USER_CONFIG_DIR}/vaultmeta.conf"

REPO_CONFIG_FILE="${REPO_ROOT}/config/vaultmeta.conf"
REPO_CONFIG_EXAMPLE="${REPO_ROOT}/config/vaultmeta.conf.example"

now_iso() { date +"%Y-%m-%dT%H:%M:%S%z"; }

trim() { echo "${1:-}" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//'; }

die() { echo "ERROR: $*" >&2; exit 1; }

prompt() {
  local msg="$1"
  local def="${2:-}"
  local ans=""
  if [[ -n "${def}" ]]; then
    read -r -p "${msg} [default: ${def}] " ans || true
    ans="$(trim "$ans")"
    [[ -z "$ans" ]] && ans="$def"
  else
    read -r -p "${msg} " ans || true
    ans="$(trim "$ans")"
  fi
  echo "$ans"
}

csv_to_lines() {
  local csv="${1:-}"
  [[ -z "$csv" ]] && return 0
  echo "$csv" | tr ',' '
' | while IFS= read -r line; do
    line="$(trim "$line")"
    [[ -n "$line" ]] && echo "$line"
  done
}

resolve_config_file() {
  # Priority:
  # 1) VAULTMETA_CONFIG
  # 2) XDG user config
  # 3) repo config (when running from repo)
  if [[ -n "${VAULTMETA_CONFIG:-}" ]]; then
    echo "${VAULTMETA_CONFIG}"
    return 0
  fi
  if [[ -f "${USER_CONFIG_FILE}" ]]; then
    echo "${USER_CONFIG_FILE}"
    return 0
  fi
  if [[ -f "${REPO_CONFIG_FILE}" ]]; then
    echo "${REPO_CONFIG_FILE}"
    return 0
  fi
  echo ""
}

load_config() {
  local cfg
  cfg="$(resolve_config_file)"
  if [[ -z "$cfg" || ! -f "$cfg" ]]; then
    die "Config not found. Looked for:
- VAULTMETA_CONFIG (env override)
- ${USER_CONFIG_FILE}
- ${REPO_CONFIG_FILE}
Create one via: ./install.sh install"
  fi

  # shellcheck disable=SC1090
  source "$cfg"

  INCLUDE_HIDDEN="${INCLUDE_HIDDEN:-0}"
  EXCLUDE_DIRS="${EXCLUDE_DIRS:-.git,node_modules}"
  EXCLUDE_GLOBS="${EXCLUDE_GLOBS:-}"
  TREE_MAX_DEPTH="${TREE_MAX_DEPTH:-6}"
  FOLLOW_SYMLINKS="${FOLLOW_SYMLINKS:-0}"
  INCLUDE_FILES="${INCLUDE_FILES:-1}"
  OUTPUT_DIR="${OUTPUT_DIR:-}"
  VAULT_ROOT="${VAULT_ROOT:-}"

  # Phase 1 settings (with safe defaults)
  CHANGES_HOURS="${CHANGES_HOURS:-24}"
  CHANGES_DAYS="${CHANGES_DAYS:-7}"
  LARGEST_TOP_N="${LARGEST_TOP_N:-50}"
  ATTACHMENT_TOP_N="${ATTACHMENT_TOP_N:-50}"

  RESOLVED_CONFIG_FILE="$cfg"
}

ensure_paths_resilient() {
  while [[ -z "${VAULT_ROOT:-}" || ! -d "${VAULT_ROOT}" ]]; do
    if [[ -n "${VAULT_ROOT:-}" && ! -d "${VAULT_ROOT}" ]]; then
      echo "Missing vault root directory: ${VAULT_ROOT}"
    fi
    VAULT_ROOT="$(prompt "Enter VAULT_ROOT (path to your Obsidian vault root):" "")"
  done

  local default_out="${VAULT_ROOT%/}/30_REFERENCE/vaultmeta"
  if [[ -z "${OUTPUT_DIR:-}" ]]; then
    OUTPUT_DIR="$(prompt "Enter output directory or press Enter to accept default:" "${default_out}")"
  fi

  if [[ ! -d "${OUTPUT_DIR}" ]]; then
    mkdir -p "${OUTPUT_DIR}" || die "Failed to create OUTPUT_DIR: ${OUTPUT_DIR}"
  fi
}

settings_summary() {
  cat <<EOF
- CONFIG_FILE: ${RESOLVED_CONFIG_FILE}
- VAULT_ROOT: ${VAULT_ROOT}
- OUTPUT_DIR: ${OUTPUT_DIR}
- INCLUDE_HIDDEN: ${INCLUDE_HIDDEN}
- EXCLUDE_DIRS: ${EXCLUDE_DIRS}
- EXCLUDE_GLOBS: ${EXCLUDE_GLOBS}
- TREE_MAX_DEPTH: ${TREE_MAX_DEPTH}
- FOLLOW_SYMLINKS: ${FOLLOW_SYMLINKS}
- INCLUDE_FILES: ${INCLUDE_FILES}
- CHANGES_HOURS: ${CHANGES_HOURS}
- CHANGES_DAYS: ${CHANGES_DAYS}
- LARGEST_TOP_N: ${LARGEST_TOP_N}
- ATTACHMENT_TOP_N: ${ATTACHMENT_TOP_N}
EOF
}

write_header() {
  local title="$1"
  cat <<EOF
---
type: vaultmeta-report
title: ${title}
generated: $(now_iso)
vault_root: ${VAULT_ROOT}
output_dir: ${OUTPUT_DIR}
version: ${VERSION}
---

## Settings Summary

$(settings_summary)

---
EOF
}

# Build find args for traversal with pruning rules, optionally with maxdepth.
# Usage: build_find_args_pruned <maxdepth or empty>
build_find_args_pruned() {
  local maxdepth="${1:-}"
  FIND_ARGS=()

  if [[ "${FOLLOW_SYMLINKS}" == "1" ]]; then
    FIND_ARGS+=("-L")
  fi

  FIND_ARGS+=("${VAULT_ROOT}")

  if [[ -n "${maxdepth}" ]]; then
    FIND_ARGS+=("-maxdepth" "${maxdepth}")
  fi

  if [[ "${INCLUDE_HIDDEN}" != "1" ]]; then
    FIND_ARGS+=("(" "-path" "*/.*" ")" "-prune" "-o")
  fi

  local d
  while IFS= read -r d; do
    FIND_ARGS+=("(" "-name" "${d}" "-type" "d" ")" "-prune" "-o")
  done < <(csv_to_lines "${EXCLUDE_DIRS}")

  local g
  while IFS= read -r g; do
    FIND_ARGS+=("(" "-name" "${g}" ")" "-prune" "-o")
  done < <(csv_to_lines "${EXCLUDE_GLOBS}")
}

# Emit: epoch<TAB>size<TAB>abs_path
stat_lines_from_find0() {
  # Reads NUL-delimited file list on stdin.
  # GNU stat (coreutils): %Y = epoch, %s = size, %n = filename
  xargs -0 stat -c '%Y	%s	%n' 2>/dev/null || true
}

epoch_to_human() {
  local epoch="${1:-}"
  if date -d "@${epoch}" "+%Y-%m-%d %H:%M" >/dev/null 2>&1; then
    date -d "@${epoch}" "+%Y-%m-%d %H:%M"
    return 0
  fi
  # Fallback
  date "+%Y-%m-%d %H:%M"
}

human_size() {
  # bytes -> rough human readable
  local b="${1:-0}"
  awk -v b="$b" 'function hr(x){
    s="B KB MB GB TB"; split(s,a," ");
    i=1;
    while (x>=1024 && i<5){x/=1024;i++}
    return sprintf("%.2f %s", x, a[i])
  } BEGIN{print hr(b)}'
}

relpath() {
  local p="$1"
  echo "${p#${VAULT_ROOT%/}/}"
}

topdir_of_relpath() {
  local r="$1"
  local top="${r%%/*}"
  [[ "${top}" == "${r}" ]] && top="(root)"
  echo "${top}"
}

normalize_rel_path() {
  local input="${1:-}"
  local -a parts=()
  local -a stack=()
  local part out

  input="${input#./}"
  IFS='/' read -r -a parts <<< "${input}"

  for part in "${parts[@]}"; do
    [[ -z "${part}" || "${part}" == "." ]] && continue
    if [[ "${part}" == ".." ]]; then
      if (( ${#stack[@]} > 0 )) && [[ "${stack[$(( ${#stack[@]} - 1 ))]}" != ".." ]]; then
        unset 'stack[${#stack[@]}-1]'
      else
        stack+=("..")
      fi
      continue
    fi
    stack+=("${part}")
  done

  out=""
  for part in "${stack[@]}"; do
    if [[ -z "${out}" ]]; then
      out="${part}"
    else
      out+="/${part}"
    fi
  done

  echo "${out}"
}

path_has_extension() {
  local name="${1##*/}"
  [[ "${name}" == *.* && "${name}" != .* ]]
}

strip_link_suffixes() {
  local target="${1:-}"
  target="${target%%#*}"
  target="${target%%\?*}"
  echo "${target}"
}

is_external_target() {
  local target="${1:-}"
  [[ "${target}" =~ ^[A-Za-z][A-Za-z0-9+.-]*: ]] || [[ "${target}" == //* ]]
}

md_inline() {
  local value="${1:-}"
  value="${value//$'\n'/ }"
  value="${value//$'\r'/ }"
  printf '%s\n' "${value}"
}

extract_links_from_markdown() {
  local file="$1"
  awk '
    {
      line = $0
      while (match(line, /\[\[[^\[\]]+\]\]/)) {
        link_start = RSTART
        link_len = RLENGTH
        full = substr(line, RSTART, RLENGTH)
        inner = substr(full, 3, length(full) - 4)
        split(inner, parts, "|")
        target = parts[1]
        display = (parts[2] != "" ? parts[2] : parts[1])
        gsub(/^[[:space:]]+|[[:space:]]+$/, "", target)
        gsub(/^[[:space:]]+|[[:space:]]+$/, "", display)
        gsub(/\t/, " ", target)
        gsub(/\t/, " ", display)
        if (target != "") {
          printf "wiki\t%s\t%s\n", display, target
        }
        line = substr(line, link_start + link_len)
      }

      line = $0
      while (match(line, /!?\[[^\[\]]*\]\([^()]*\)/)) {
        link_start = RSTART
        link_len = RLENGTH
        full = substr(line, RSTART, RLENGTH)
        raw = full
        if (substr(raw, 1, 1) == "!") {
          raw = substr(raw, 2)
        }

        splitpos = index(raw, "](")
        if (splitpos > 0) {
          text = substr(raw, 2, splitpos - 2)
          inside = substr(raw, splitpos + 2, length(raw) - splitpos - 2)
          target = inside

          gsub(/^[[:space:]]+|[[:space:]]+$/, "", target)
          if (substr(target, 1, 1) == "<" && index(target, ">") > 1) {
            target = substr(target, 2, index(target, ">") - 2)
          } else {
            sub(/[[:space:]].*$/, "", target)
          }

          gsub(/^[[:space:]]+|[[:space:]]+$/, "", text)
          gsub(/^[[:space:]]+|[[:space:]]+$/, "", target)
          gsub(/\t/, " ", text)
          gsub(/\t/, " ", target)

          if (target != "") {
            printf "md\t%s\t%s\n", text, target
          }
        }

        line = substr(line, link_start + link_len)
      }
    }
  ' "${file}"
}

report_tree() {
  ensure_paths_resilient
  build_find_args_pruned "${TREE_MAX_DEPTH}"

  local out="${OUTPUT_DIR%/}/VaultMeta - File Tree.md"
  {
    write_header "VaultMeta - File Tree"
    echo "# 🌿 VaultMeta — File Tree"
    echo
    echo "_Stable note. Overwritten each run._"
    echo
    echo "## Tree"
    echo

    local include_files="${INCLUDE_FILES}"
    if [[ "${include_files}" == "1" ]]; then
      find "${FIND_ARGS[@]}" -print         | sed "s#^${VAULT_ROOT%/}/##"         | sed 's#^$#.#'         | sort         | awk -F'/' '
          {
            depth = NF - 1
            indent = ""
            for (i=0; i<depth; i++) indent = indent "  "
            name = $NF
            if ($0 == ".") { name="(vault root)"; indent="" }
            print indent "- " name
          }'
    else
      find "${FIND_ARGS[@]}" -type d -print         | sed "s#^${VAULT_ROOT%/}/##"         | sed 's#^$#.#'         | sort         | awk -F'/' '
          {
            depth = NF - 1
            indent = ""
            for (i=0; i<depth; i++) indent = indent "  "
            name = $NF
            if ($0 == ".") { name="(vault root)"; indent="" }
            print indent "- " name
          }'
    fi
  } > "${out}"
  echo "Wrote: ${out}"
}

report_dirs() {
  ensure_paths_resilient
  build_find_args_pruned ""  # full depth for directory blocks

  local out="${OUTPUT_DIR%/}/VaultMeta - Directory Blocks.md"
  {
    write_header "VaultMeta - Directory Blocks"
    echo "# 📁 VaultMeta — Directory Blocks"
    echo
    echo "_Stable note. Overwritten each run._"
    echo
    echo "## Vault Root"
    echo
    echo '```bash'
    echo "${VAULT_ROOT}"
    echo '```'
    echo

    # Collect directories (absolute), exclude VAULT_ROOT itself
    mapfile -t dirs < <(find "${FIND_ARGS[@]}" -type d -print | sort | grep -v "^${VAULT_ROOT%/}$" || true)

    local current_top=""
    local d rel top

    for d in "${dirs[@]}"; do
      rel="$(relpath "$d")"
      top="$(topdir_of_relpath "$rel")"
      if [[ "${top}" != "${current_top}" ]]; then
        current_top="${top}"
        echo "## ${current_top}"
        echo
      fi

      echo '```bash'
      echo "${d}"
      echo '```'
      echo
    done
  } > "${out}"
  echo "Wrote: ${out}"
}

report_changes() {
  ensure_paths_resilient
  build_find_args_pruned ""  # full depth
  local out="${OUTPUT_DIR%/}/VaultMeta - Recent Changes.md"

  # Hours window uses -mmin; Days uses -mtime.
  local hours="${CHANGES_HOURS}"
  local days="${CHANGES_DAYS}"

  {
    write_header "VaultMeta - Recent Changes"
    echo "# 🕒 VaultMeta — Recent Changes"
    echo
    echo "_Stable note. Overwritten each run._"
    echo
    echo "## Summary"
    echo
    echo "- Window A: last ${hours} hours"
    echo "- Window B: last ${days} days"
    echo

    for mode in "hours" "days"; do
      local label find_time_args
      if [[ "${mode}" == "hours" ]]; then
        label="Last ${hours} hours"
        # -mmin -1440 for 24h; use integer minutes
        local mins=$(( hours * 60 ))
        find_time_args=( -type f -mmin "-${mins}" )
      else
        label="Last ${days} days"
        find_time_args=( -type f -mtime "-${days}" )
      fi

      echo "## ${label}"
      echo

      # Produce: epoch size path
      local lines
      lines="$(find "${FIND_ARGS[@]}" "${find_time_args[@]}" -print0 | stat_lines_from_find0)"

      if [[ -z "${lines}" ]]; then
        echo "_No matching files._"
        echo
        continue
      fi

      # Sort by epoch desc
      # shellcheck disable=SC2005
      local sorted
      sorted="$(echo "${lines}" | sort -nr -k1,1)"

      # Count
      local count
      count="$(echo "${sorted}" | wc -l | tr -d ' ')"
      echo "- Files: ${count}"
      echo

      # Group by top-level dir
      local current_top=""
      echo "${sorted}" | while IFS=$'	' read -r epoch size path; do
        local rel top ts hs
        rel="$(relpath "$path")"
        top="$(topdir_of_relpath "$rel")"
        if [[ "${top}" != "${current_top}" ]]; then
          current_top="${top}"
          echo "### ${current_top}"
          echo
        fi
        ts="$(epoch_to_human "${epoch}")"
        hs="$(human_size "${size}")"
        echo "- ${ts} — \`${rel}\` (${hs})"
      done
      echo
    done
  } > "${out}"
  echo "Wrote: ${out}"
}

report_largest() {
  ensure_paths_resilient
  build_find_args_pruned ""  # full depth
  local out="${OUTPUT_DIR%/}/VaultMeta - Largest Files.md"
  local n="${LARGEST_TOP_N}"

  {
    write_header "VaultMeta - Largest Files"
    echo "# 🧱 VaultMeta — Largest Files"
    echo
    echo "_Stable note. Overwritten each run._"
    echo
    echo "## Top ${n}"
    echo
    echo "| size | path |"
    echo "|---:|---|"

    local lines
    lines="$(find "${FIND_ARGS[@]}" -type f -print0 | stat_lines_from_find0)"
    if [[ -z "${lines}" ]]; then
      echo "| 0 B | _No files found_ |"
      echo
      exit 0
    fi

    echo "${lines}"       | awk -F'	' '{print $2 "	" $3}'       | sort -nr -k1,1       | awk -v n="${n}" 'NR<=n {print}'       | while IFS=$'	' read -r size path; do
          local rel hs
          rel="$(relpath "$path")"
          hs="$(human_size "$size")"
          echo "| ${hs} | \`${rel}\` |"
        done
    echo
  } > "${out}"
  echo "Wrote: ${out}"
}

report_attachments() {
  ensure_paths_resilient
  build_find_args_pruned ""  # full depth
  local out="${OUTPUT_DIR%/}/VaultMeta - Attachment Audit.md"
  local n="${ATTACHMENT_TOP_N}"

  {
    write_header "VaultMeta - Attachment Audit"
    echo "# 📎 VaultMeta — Attachment Audit"
    echo
    echo "_Stable note. Overwritten each run._"
    echo
    echo "## Summary"
    echo
    echo '- Definition: non-`.md` files under VAULT_ROOT'
    echo

    local lines
    lines="$(find "${FIND_ARGS[@]}" -type f ! -name "*.md" -print0 | stat_lines_from_find0)"
    if [[ -z "${lines}" ]]; then
      echo "_No non-markdown files found._"
      echo
      exit 0
    fi

    local count
    count="$(echo "${lines}" | wc -l | tr -d ' ')"
    echo "- Files: ${count}"
    echo

    echo "## By extension"
    echo
    echo "| ext | count | total size |"
    echo "|---|---:|---:|"
    echo "${lines}"       | awk -F'	' '
        function lower(s){ for(i=1;i<=length(s);i++){c=substr(s,i,1); if(c>="A"&&c<="Z") c=tolower(c); out=out c} r=out; out=""; return r }
        function ext(p){
          n=split(p,a,"/");
          f=a[n];
          if (index(f,".")==0) return "(none)";
          e=substr(f, match(f, /\.[^\.]*$/)+1);
          return lower(e);
        }
        { e=ext($3); cnt[e]++; sum[e]+=$2 }
        END{
          for (k in cnt){
            printf "%s\t%d\t%d\n", k, cnt[k], sum[k]
          }
        }'       | sort -nr -k2,2       | while IFS=$'	' read -r e c s; do
          hs="$(human_size "$s")"
          echo "| ${e} | ${c} | ${hs} |"
        done
    echo

    echo "## Largest ${n} attachments"
    echo
    echo "| size | path |"
    echo "|---:|---|"
    echo "${lines}"       | awk -F'	' '{print $2 "	" $3}'       | sort -nr -k1,1       | awk -v n="${n}" 'NR<=n {print}'       | while IFS=$'	' read -r size path; do
          rel="$(relpath "$path")"
          hs="$(human_size "$size")"
          echo "| ${hs} | \`${rel}\` |"
        done
    echo
  } > "${out}"
  echo "Wrote: ${out}"
}

report_broken_links() {
  ensure_paths_resilient
  build_find_args_pruned ""  # full depth

  local out="${OUTPUT_DIR%/}/VaultMeta - Broken Links.md"
  local tmp_broken="${OUTPUT_DIR%/}/.vaultmeta-broken-links.${BASHPID}.tsv"
  rm -f "${tmp_broken}"

  local -a all_files=()
  local -a md_files=()
  local abs rel base
  local notes_scanned=0
  local links_evaluated=0
  local links_broken=0
  local skipped_non_local=0
  local source_count_with_broken=0

  declare -A file_set=()
  declare -A note_basename_set=()
  declare -A file_basename_set=()
  declare -A broken_sources=()

  mapfile -d '' -t all_files < <(find "${FIND_ARGS[@]}" -type f -print0)

  for abs in "${all_files[@]}"; do
    rel="$(relpath "${abs}")"
    file_set["${rel}"]=1
    base="${rel##*/}"
    file_basename_set["${base}"]=1
    if [[ "${base}" == *.md ]]; then
      note_basename_set["${base%.md}"]=1
      md_files+=("${abs}")
    fi
  done

  notes_scanned="${#md_files[@]}"

  local source_abs source_rel source_dir
  local kind link_text raw_target
  local target stripped_target
  local candidate candidate_md source_candidate source_candidate_md
  local resolved display unresolved_form

  for source_abs in "${md_files[@]}"; do
    source_rel="$(relpath "${source_abs}")"
    source_dir="$(dirname "${source_rel}")"
    [[ "${source_dir}" == "." ]] && source_dir=""

    while IFS=$'\t' read -r kind link_text raw_target; do
      [[ -n "${raw_target}" ]] || continue

      target="$(trim "${raw_target}")"
      [[ -n "${target}" ]] || continue

      if is_external_target "${target}"; then
        skipped_non_local=$((skipped_non_local + 1))
        continue
      fi

      stripped_target="$(strip_link_suffixes "${target}")"
      stripped_target="$(trim "${stripped_target}")"

      if [[ -z "${stripped_target}" ]]; then
        skipped_non_local=$((skipped_non_local + 1))
        continue
      fi

      links_evaluated=$((links_evaluated + 1))
      resolved=0
      unresolved_form="${stripped_target}"

      if [[ "${kind}" == "md" ]]; then
        if [[ "${stripped_target}" == /* ]]; then
          candidate="$(normalize_rel_path "${stripped_target#/}")"
        else
          candidate="$(normalize_rel_path "${source_dir:+${source_dir}/}${stripped_target}")"
        fi

        unresolved_form="${candidate:-${stripped_target}}"
        if [[ -n "${candidate}" && "${candidate}" != .. && "${candidate}" != ../* && -n "${file_set[${candidate}]:-}" ]]; then
          resolved=1
        elif [[ -n "${candidate}" && "${candidate}" != .. && "${candidate}" != ../* ]]; then
          if ! path_has_extension "${candidate}"; then
            candidate_md="${candidate}.md"
            unresolved_form="${candidate_md}"
            [[ -n "${file_set[${candidate_md}]:-}" ]] && resolved=1
          fi
        fi
      else
        if [[ "${stripped_target}" == /* ]]; then
          candidate="$(normalize_rel_path "${stripped_target#/}")"
          unresolved_form="${candidate:-${stripped_target}}"
          if [[ -n "${candidate}" && "${candidate}" != .. && "${candidate}" != ../* && -n "${file_set[${candidate}]:-}" ]]; then
            resolved=1
          elif [[ -n "${candidate}" && "${candidate}" != .. && "${candidate}" != ../* ]]; then
            if ! path_has_extension "${candidate}"; then
              candidate_md="${candidate}.md"
              unresolved_form="${candidate_md}"
              [[ -n "${file_set[${candidate_md}]:-}" ]] && resolved=1
            fi
          fi
        elif [[ "${stripped_target}" == */* || "${stripped_target}" == ./* || "${stripped_target}" == ../* ]]; then
          if [[ "${stripped_target}" == ./* || "${stripped_target}" == ../* ]]; then
            candidate="$(normalize_rel_path "${source_dir:+${source_dir}/}${stripped_target}")"
          else
            candidate="$(normalize_rel_path "${stripped_target}")"
          fi

          unresolved_form="${candidate:-${stripped_target}}"
          if [[ -n "${candidate}" && "${candidate}" != .. && "${candidate}" != ../* && -n "${file_set[${candidate}]:-}" ]]; then
            resolved=1
          elif [[ -n "${candidate}" && "${candidate}" != .. && "${candidate}" != ../* ]]; then
            if ! path_has_extension "${candidate}"; then
              candidate_md="${candidate}.md"
              unresolved_form="${candidate_md}"
              [[ -n "${file_set[${candidate_md}]:-}" ]] && resolved=1
            fi
          fi
        else
          if path_has_extension "${stripped_target}"; then
            unresolved_form="${stripped_target}"
            if [[ -n "${file_basename_set[${stripped_target}]:-}" ]]; then
              resolved=1
            else
              candidate="$(normalize_rel_path "${stripped_target}")"
              source_candidate="$(normalize_rel_path "${source_dir:+${source_dir}/}${stripped_target}")"
              if [[ -n "${candidate}" && -n "${file_set[${candidate}]:-}" ]]; then
                resolved=1
              elif [[ -n "${source_candidate}" && -n "${file_set[${source_candidate}]:-}" ]]; then
                resolved=1
              fi
            fi
          else
            unresolved_form="${stripped_target}.md"
            if [[ -n "${note_basename_set[${stripped_target}]:-}" ]]; then
              resolved=1
            else
              candidate_md="$(normalize_rel_path "${stripped_target}.md")"
              source_candidate_md="$(normalize_rel_path "${source_dir:+${source_dir}/}${stripped_target}.md")"
              if [[ -n "${candidate_md}" && -n "${file_set[${candidate_md}]:-}" ]]; then
                resolved=1
              elif [[ -n "${source_candidate_md}" && -n "${file_set[${source_candidate_md}]:-}" ]]; then
                resolved=1
              fi
            fi
          fi
        fi
      fi

      if [[ "${resolved}" -eq 0 ]]; then
        links_broken=$((links_broken + 1))
        broken_sources["${source_rel}"]=1
        display="$(trim "${link_text}")"
        [[ -z "${display}" ]] && display="${target}"
        printf '%s\t%s\t%s\t%s\t%s\n' "${source_rel}" "${kind}" "${display}" "${target}" "${unresolved_form}" >> "${tmp_broken}"
      fi
    done < <(extract_links_from_markdown "${source_abs}")
  done

  source_count_with_broken="${#broken_sources[@]}"

  {
    write_header "VaultMeta - Broken Links"
    echo "# 🔗 VaultMeta — Broken Links"
    echo
    echo "_Stable note. Overwritten each run._"
    echo
    echo "## Summary"
    echo
    echo "- Notes scanned: ${notes_scanned}"
    echo "- Local links evaluated: ${links_evaluated}"
    echo "- Broken local links: ${links_broken}"
    echo "- Source notes with broken links: ${source_count_with_broken}"
    echo "- Skipped external/anchor-only links: ${skipped_non_local}"
    echo

    echo "## Broken entries by source note"
    echo

    if [[ ! -s "${tmp_broken}" ]]; then
      echo "_No broken local links found._"
      echo
    else
      local current_source=""
      local out_source out_kind out_display out_raw out_unresolved
      while IFS=$'\t' read -r out_source out_kind out_display out_raw out_unresolved; do
        if [[ "${out_source}" != "${current_source}" ]]; then
          current_source="${out_source}"
          echo "### \`${current_source}\`"
          echo
        fi
        echo "- source note: \`$(md_inline "${out_source}")\` | link text/raw target: \`$(md_inline "${out_display}")\` (raw: \`$(md_inline "${out_raw}")\`) | unresolved target form: \`$(md_inline "${out_unresolved}")\`"
      done < <(sort -t $'\t' -k1,1 -k5,5 "${tmp_broken}")
      echo
    fi
  } > "${out}"

  rm -f "${tmp_broken}"
  echo "Wrote: ${out}"
}

ensure_termux_outputs_dir() {
  local default_dir="/storage/emulated/0/Documents/HeartloomVault/30_REFERENCE/termux-outputs"
  TERMUX_OUTPUT_DIR="${TERMUX_OUTPUT_DIR:-${default_dir}}"

  if [[ -d "${TERMUX_OUTPUT_DIR}" ]]; then
    return 0
  fi

  echo "Output directory not found:"
  echo "  ${TERMUX_OUTPUT_DIR}"
  echo
  TERMUX_OUTPUT_DIR="$(prompt "Enter a new output directory path, or press Enter to create/use the default:" "${default_dir}")"
  mkdir -p "${TERMUX_OUTPUT_DIR}" || die "Failed to create output directory: ${TERMUX_OUTPUT_DIR}"
}

report_termux_packages() {
  # Writes into canonical Termux outputs dir (within the vault).
  ensure_termux_outputs_dir

  local out="${TERMUX_OUTPUT_DIR%/}/termux_packages.md"

  {
    echo "---"
    echo "type: vaultmeta-report"
    echo "title: termux-packages"
    echo "generated: $(now_iso)"
    echo "version: ${VERSION}"
    echo "---"
    echo
    echo "# 📦 Termux Packages"
    echo
    echo "## Device basics"
    echo
    echo "- uname: \`$(uname -a 2>/dev/null || echo "unknown")\`"
    if command -v termux-info >/dev/null 2>&1; then
      echo
      echo "### termux-info"
      echo
      echo '```'
      termux-info 2>/dev/null || true
      echo '```'
    fi

    echo
    echo "### Storage sanity"
    echo
    echo "- /storage/emulated/0 exists: $( [[ -d /storage/emulated/0 ]] && echo "yes" || echo "no" )"
    echo "- \$HOME/storage exists: $( [[ -d "${HOME}/storage" ]] && echo "yes" || echo "no" )"
    echo

    echo "## Summary"
    echo
    local pkg_lines
    if command -v dpkg-query >/dev/null 2>&1; then
      pkg_lines="$(dpkg-query -W -f='${Package}	${Version}
' 2>/dev/null || true)"
    else
      pkg_lines=""
    fi
    local pkg_count
    pkg_count="$(echo "${pkg_lines}" | sed '/^$/d' | wc -l | tr -d ' ')"
    echo "- Packages (dpkg-query): ${pkg_count}"
    echo

    echo "## Packages (dpkg-query)"
    echo
    echo "| package | version |"
    echo "|---|---|"
    if [[ -n "${pkg_lines}" ]]; then
      echo "${pkg_lines}" | sed '/^$/d' | while IFS=$'	' read -r p v; do
        echo "| ${p} | ${v} |"
      done
    else
      echo "| _dpkg-query not available_ |  |"
    fi
    echo

    if command -v pkg >/dev/null 2>&1; then
      echo "## Packages (pkg list-installed)"
      echo
      echo '```'
      pkg list-installed 2>/dev/null || true
      echo '```'
      echo
    fi

    echo "## Repo + config anchors"
    echo
    if command -v git >/dev/null 2>&1; then
      local gname gemail
      gname="$(git config --global user.name 2>/dev/null || true)"
      gemail="$(git config --global user.email 2>/dev/null || true)"
      [[ -n "${gname}" ]] && echo "- git user.name: \`${gname}\`"
      [[ -n "${gemail}" ]] && echo "- git user.email: \`${gemail}\`"
      [[ -z "${gname}${gemail}" ]] && echo "- git identity: _(not set)_"
    else
      echo "- git: _(not installed)_"
    fi
    echo
    echo "### Important dotfiles present (names only)"
    echo
    echo "- ~/.gitconfig: $( [[ -f "${HOME}/.gitconfig" ]] && echo "yes" || echo "no" )"
    echo "- ~/.ssh/: $( [[ -d "${HOME}/.ssh" ]] && echo "yes" || echo "no" )"
    echo "- ~/.config/: $( [[ -d "${HOME}/.config" ]] && echo "yes" || echo "no" )"
    echo "- ~/.shortcuts/: $( [[ -d "${HOME}/.shortcuts" ]] && echo "yes" || echo "no" )"
    echo

    echo "## Apt sources + held packages"
    echo
    if [[ -n "${PREFIX:-}" ]]; then
      local sources="${PREFIX}/etc/apt/sources.list"
      local sourcesd="${PREFIX}/etc/apt/sources.list.d"
      echo "### sources.list"
      echo
      if [[ -f "${sources}" ]]; then
        echo '```'
        echo "# ${sources}"
        cat "${sources}" 2>/dev/null || true
        echo '```'
      else
        echo "_Missing: ${sources}_"
      fi
      echo
      echo "### sources.list.d"
      echo
      if [[ -d "${sourcesd}" ]]; then
        for f in "${sourcesd}"/*; do
          [[ -f "${f}" ]] || continue
          echo '```'
          echo "# ${f}"
          cat "${f}" 2>/dev/null || true
          echo '```'
          echo
        done
      else
        echo "_Missing: ${sourcesd}_"
        echo
      fi
    else
      echo "_PREFIX not set; cannot locate apt sources._"
      echo
    fi

    echo "### Held packages"
    echo
    if command -v apt-mark >/dev/null 2>&1; then
      echo '```'
      apt-mark showhold 2>/dev/null || true
      echo '```'
    else
      # dpkg hold fallback
      if command -v dpkg >/dev/null 2>&1; then
        echo '```'
        dpkg --get-selections 2>/dev/null | awk '$2=="hold"{print $1}' || true
        echo '```'
      else
        echo "_No apt-mark/dpkg available._"
      fi
    fi
    echo

    echo "## Language ecosystems (optional sections)"
    echo

    if command -v python >/dev/null 2>&1; then
      echo "### Python"
      echo
      echo "- python: \`$(python --version 2>&1 | tr -d '')\`"
      if command -v pip >/dev/null 2>&1; then
        echo
        echo "#### pip list"
        echo
        echo '```'
        pip list 2>/dev/null || true
        echo '```'
      fi
      echo
    fi

    if command -v node >/dev/null 2>&1; then
      echo "### Node"
      echo
      echo "- node: \`$(node --version 2>/dev/null || true)\`"
      if command -v npm >/dev/null 2>&1; then
        echo
        echo "#### npm -g list --depth=0"
        echo
        echo '```'
        npm -g list --depth=0 2>/dev/null || true
        echo '```'
      fi
      echo
    fi

    if command -v go >/dev/null 2>&1; then
      echo "### Go"
      echo
      echo "- go: \`$(go version 2>/dev/null || true)\`"
      echo
    fi

    if command -v rustc >/dev/null 2>&1; then
      echo "### Rust"
      echo
      echo "- rustc: \`$(rustc --version 2>/dev/null || true)\`"
      echo
    fi

  } > "${out}"

  echo "Wrote: ${out}"
}

cmd_status() {
  ensure_paths_resilient
  echo "${SCRIPT_NAME} ${VERSION}"
  echo
  settings_summary
}

usage() {
  cat <<EOF
${SCRIPT_NAME} ${VERSION}

Usage:
  vaultmeta                      Run all reports (Phase 0 + Phase 1)
  vaultmeta tree                 Generate File Tree report
  vaultmeta dirs                 Generate Directory Blocks report
  vaultmeta changes              Generate Recent Changes report
  vaultmeta largest              Generate Largest Files report
  vaultmeta broken-links         Generate Broken Links report
  vaultmeta attachments           Generate Attachment Audit report
  vaultmeta termux-packages       Generate Termux packages report (writes into vault termux-outputs)
  vaultmeta status               Print resolved config and effective settings (no file writes)
  vaultmeta help                 Show this help

Config search order:
  1) VAULTMETA_CONFIG (env override)
  2) ${USER_CONFIG_FILE}
  3) ${REPO_CONFIG_FILE}

EOF
}

run_all() {
  report_tree
  report_dirs
  report_changes
  report_largest
  report_broken_links
  report_attachments
  report_termux_packages
}

main() {
  local cmd="${1:-}"
  load_config

  case "${cmd}" in
    "" ) run_all ;;
    tree ) report_tree ;;
    dirs ) report_dirs ;;
    changes ) report_changes ;;
    largest ) report_largest ;;
    broken-links ) report_broken_links ;;
    attachments ) report_attachments ;;
    termux-packages ) report_termux_packages ;;
    status ) cmd_status ;;
    help|-h|--help ) usage ;;
    * ) echo "Unknown command: ${cmd}" >&2; usage; exit 2 ;;
  esac
}

main "$@"

